# ── Biến môi trường bắt buộc ─────────────────────────────────────────────
# Copy file này thành .env và điền các giá trị thực

# Môi trường chạy: development hoặc production
APP_ENV = development

# ── CORS Configuration ───────────────────────────────────────────────────
# Danh sách các domain được phép gọi API, phân tách bằng dấu phẩy
BACKEND_CORS_ORIGINS = http://localhost:5173,http://127.0.0.1:5173
# Ví dụ trên production:
# BACKEND_CORS_ORIGINS = https://xepthung.tech,https://www.xepthung.tech

# Danh sách các Host header hợp lệ, phân tách bằng dấu phẩy
BACKEND_ALLOWED_HOSTS = localhost,127.0.0.1
# Ví dụ trên production:
# BACKEND_ALLOWED_HOSTS = xepthung.tech,www.xepthung.tech

# ── Supabase ─────────────────────────────────────────────────────────────
# Lấy tại: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL = https://your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY = your-service-role-key-here

# ── Database (PostgreSQL Connection String) ──────────────────────────────
# Lấy tại: Supabase Dashboard → Settings → Database → Connection String (URI mode)
# Lưu ý: Dùng Transaction Pooler (port 6543) nếu deploy lên Render
DATABASE_URL = postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
